{
  "manifest_version": 3,
  "name": "Lockout",
  "version": "0.1.0",
  "description": "Block futures trading with commitment-based lockout",
  "permissions": [
    "storage",
    "webRequest",
    "declarativeNetRequest",
    "tabs"
  ],
  "host_permissions": [
    "*://*.breakoutprop.com/*",
    "*://*.topstep.com/*",
    "*://*.robinhood.com/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.breakoutprop.com/*",
        "*://*.topstep.com/*",
        "*://*.robinhood.com/*"
      ],
      "js": ["content/overlay.js"],
      "css": ["content/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html"
  }
}
